# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# --- Google Gemini (default provider) ---
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# --- NVIDIA Nemotron (optional alternative provider) ---
# Get a free API key at https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-your-key-here

# Set to "nemotron" to use Nemotron instead of Gemini in notebooks / scripts.
# Supported values: gemini | nemotron
LLM_PROVIDER=gemini
